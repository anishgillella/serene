# Serene Environment Configuration
# Place this file in the ROOT directory of the project as .env
# Both backend and frontend will read from this single file
#
# Local dev ports (see docs/project/PORTS.md):
#   API 8100 | Frontend 8101 | Redis 6380 | Preview 8102
SERENE_API_PORT=8100
SERENE_FRONTEND_PORT=8101
SERENE_REDIS_PORT=6380

# ============================================
# LiveKit Configuration
# ============================================
LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_AGENT_NAME=luna-mediator

# Moss — sub-10ms semantic search for Luna voice agent (agent worker only)
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_TRANSCRIPTS_INDEX=serene-transcripts
MOSS_MEMORY_INDEX=serene-memory
MOSS_KNOWLEDGE_INDEX=serene-knowledge

# ============================================
# AI Services
# ============================================
OPENROUTER_API_KEY=sk-or-xxx
DEEPGRAM_API_KEY=xxx
ELEVENLABS_API_KEY=sk_xxx
VOYAGE_API_KEY=pa-xxx
MISTRAL_API_KEY=xxx

# ============================================
# Databases
# ============================================
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
PINECONE_API_KEY=xxx

# ============================================
# AWS S3 Storage
# ============================================
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=us-east-1
S3_BUCKET_NAME=serene-relationship-mediator

# ============================================
# Auth0 Configuration (Backend)
# ============================================
AUTH0_DOMAIN=dev-xxxxxxxxx.us.auth0.com
AUTH0_AUDIENCE=https://api.serene.app
AUTH_OPTIONAL=true  # Set to false in production

# ============================================
# Redis (local dev uses port 6380 to avoid conflicts)
# ============================================
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ============================================
# Deployment (Railway)
# ============================================
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-api.up.railway.app
# ENABLE_SECURITY_MIDDLEWARE=true

# ============================================
# Frontend Variables (VITE_ prefix required)
# ============================================
VITE_API_URL=http://localhost:8100
ALLOWED_ORIGINS=http://localhost:8101
VITE_LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
VITE_AUTH0_DOMAIN=dev-xxxxxxxxx.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_client_id
VITE_AUTH0_AUDIENCE=https://api.serene.app

# ============================================
# Langfuse Observability (Optional)
# ============================================
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_BASE_URL=https://cloud.langfuse.com
